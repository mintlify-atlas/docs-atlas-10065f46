  "keyFeatures": [
    "OpenAPI 3.0 and 3.1 specification support",
    "JAX-RS 2.x annotation scanning (javax and jakarta namespaces)",
    "Rich set of Java annotations for documenting REST APIs",
    "Maven and Gradle build plugins for spec generation at build time",
    "Extensible ModelConverter SPI for custom type resolution",
    "OpenAPISpecFilter SPI for post-processing and filtering the generated spec",
    "Servlet integration for serving the OpenAPI document at runtime",
    "Jackson-based JSON/YAML serialization of OpenAPI models"
  ],
